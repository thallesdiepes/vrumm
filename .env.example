# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL base da aplicação (importante para callbacks OAuth e redirect Stripe)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — Developers → API keys
# Modo teste: chaves começam com sk_test_ e pk_test_
# Modo live: chaves começam com sk_live_ e pk_live_
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe — Webhook signing secret (Developers → Webhooks → seu endpoint)
# Dev local: criado pelo "stripe listen --forward-to localhost:3000/api/stripe/webhook"
# Produção: criado ao registrar o endpoint público no painel Stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# n8n Webhook (integração WhatsApp — opcional)
N8N_WEBHOOK_URL=https://seu-n8n.com/webhook/whatsapp
